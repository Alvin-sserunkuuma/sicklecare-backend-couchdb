{
  "name": "sicklecare-backend-couchdb",
  "version": "1.0.0",
  "description": "SickleCare REST API server (Express) backed by CouchDB - alternate implementation for comparison against the Postgres version (sicklecare-backend)",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
