# Server
PORT=4001
NODE_ENV=development

# CouchDB (local Docker instance - use a CouchDB-compatible server such as
# pouchdb-server for sandbox/dev testing without Docker)
COUCHDB_URL=http://sicklecare:sicklecare@localhost:5984
COUCHDB_DB_PREFIX=sicklecare_

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ML microservice (Layer 4 - Prediction Service)
ML_SERVICE_URL=http://localhost:8001

# Google Fit (Layer 5 - external integration, optional wearable sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4001/api/wearable/callback
